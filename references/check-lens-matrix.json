      "required_lenses": ["contract_fit", "mechanics_pressure", "operational_feasibility"],
      "optional_lenses": ["expression_integrity", "delivery_handoff", "boundary_risk"],
      "default_weights": {
        "contract_fit": 0.25,
        "mechanics_pressure": 0.25,
        "operational_feasibility": 0.2,
        "expression_integrity": 0.1,
        "delivery_handoff": 0.1,
        "boundary_risk": 0.1
      }
    },
    {

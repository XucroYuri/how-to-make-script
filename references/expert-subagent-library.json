    {
      "id": "cast.franchise-continuity-board",
      "team_mode": "franchise_continuity_board",
      "core_roles": ["room_captain", "continuity_keeper", "story_architect", "character_lead", "subagent.review-board-auditor", "human_decision_owner"],

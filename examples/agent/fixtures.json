  {"id":"fx.quality-04","type":"example_fixture","query":"我刚改完这个品牌片的 voice style guide，给我一个 recheck 模式的 quality gate report，只看变更范围和一个邻接 lens。","intent":"polish","medium":"branded_film","stage":"dialogue","output":"quality_gate_report","constraints":{"target_contract":"voice_style_guide","audit_scope":"recheck","recheck_mode":"range_limited_after_fix"},"expected_route":{"skill_id":"skill.quality-gating","protocol_id":"wp.quality-gate-report","rubric_id":"rb.quality-gate-report"},"key_checks":["report should define recheck scope","should include one adjacent side-effect lens"]},
  {"id":"fx.quality-05","type":"example_fixture","query":"这份给 previz 的动画 screen-to-video brief 在交给执行前做个 quality gate report，重点看 invariants 和 operational feasibility。","intent":"adapt","medium":"animation","stage":"adaptation","output":"quality_gate_report","constraints":{"target_contract":"screen_to_video_brief","audit_scope":"lens_targeted","lens_focus":"invariants_and_operational_feasibility","check_depth":"delivery_ready"},"expected_route":{"skill_id":"skill.quality-gating","protocol_id":"wp.quality-gate-report","rubric_id":"rb.quality-gate-report"},"key_checks":["report should prioritize bridge execution risks","should not review it like an ordinary scene draft"]},
  {"id":"fx.quality-06","type":"example_fixture","query":"把这个 writers room team workflow blueprint 做一个 quality gate report，我要看 handoff 和 checkpoint 到底能不能落地。","intent":"diagnose","medium":"episodic","stage":"adaptation","output":"quality_gate_report","constraints":{"target_contract":"team_workflow_blueprint","audit_scope":"full_audit","check_depth":"acceptance","acceptance_bar":"handoff_ready"},"expected_route":{"skill_id":"skill.quality-gating","protocol_id":"wp.quality-gate-report","rubric_id":"rb.quality-gate-report"},"key_checks":["report should treat it as a governance artifact","delivery or handoff lens should be explicit"]}

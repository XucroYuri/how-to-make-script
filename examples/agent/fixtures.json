  {"id":"fx.team-01","type":"example_fixture","query":"帮我给这部原创电影项目设计一个 multi-agent team workflow blueprint，要像 feature development team 一样推进。","intent":"design","medium":"feature_film","stage":"premise","output":"team_workflow_blueprint","constraints":{"team_mode":"feature_dev_pod","coordination_model":"hybrid_room","human_gate_level":"high"},"expected_route":{"skill_id":"skill.team-orchestration","protocol_id":"wp.team-workflow-blueprint","rubric_id":"rb.team-workflow-blueprint"},"key_checks":["blueprint should justify feature mode","should include handoff packets and human gates"]},

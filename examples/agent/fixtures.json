  {"id":"fx.pattern-02","type":"example_fixture","query":"我想写一条 15 秒短视频广告，先给我一个 pattern reference pack，告诉我什么 hook 写法更容易成立。","intent":"discover","medium":"shortform_video","stage":"scene","output":"pattern_reference_pack","constraints":{"creative_problem":"hook_to_proof","scenario_family":"commercial"},"expected_route":{"skill_id":"skill.pattern-reference","protocol_id":"wp.pattern-reference-pack","rubric_id":"rb.pattern-reference-pack"},"key_checks":["should stay commercial-specific","should include non-dogma note"]},
  {"id":"fx.pattern-03","type":"example_fixture","query":"做互动悬疑时，我想知道怎样的分支证据设计更强，给我一个 pattern reference pack 和失败对照。","intent":"diagnose","medium":"branching_interactive","stage":"structure","output":"pattern_reference_pack","constraints":{"creative_problem":"branching_evidence_design","scenario_family":"interactive"},"expected_route":{"skill_id":"skill.pattern-reference","protocol_id":"wp.pattern-reference-pack","rubric_id":"rb.pattern-reference-pack"},"key_checks":["should include stateful branch contrast","should explain failure mechanism"]},

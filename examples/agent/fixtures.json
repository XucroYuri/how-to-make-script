  {"id":"fx.bridge-01","type":"example_fixture","query":"把这条 8 秒护肤品牌片场景桥接成一个给 Sora 用的 screen to video brief，保住克制感，不要写成提示词杂烩。","intent":"adapt","medium":"shortform_video","stage":"adaptation","output":"screen_to_video_brief","constraints":{"prompt_runtime":"sora","duration_seconds":8,"shot_granularity":"single_clip","continuity_invariants":"premium_restraint"},"expected_route":{"skill_id":"skill.screen-to-video-bridge","protocol_id":"wp.screen-to-video-brief","rubric_id":"rb.screen-to-video-brief"},"key_checks":["bridge should preserve scene intent","should declare invariants and avoid overload"]},

  {"id":"fx.loading-01","type":"example_fixture","query":"在回答这个电影 premise 之前，先给我一个 context loading plan，说明你会加载哪些核心内容、为什么。","intent":"design","medium":"feature_film","stage":"premise","output":"context_loading_plan","constraints":{"creative_problem":"premise_design","loading_mode":"focus_pack"},"expected_route":{"skill_id":"skill.context-governor","protocol_id":"wp.context-loading-plan","rubric_id":"rb.context-loading-plan"},"key_checks":["should identify primary route","should separate mandatory and optional loading"]},
